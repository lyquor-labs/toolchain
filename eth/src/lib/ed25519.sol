//////////////////////////////////////////*/

// -2 mod(p), used to accelerate inversion and doubling operations by avoiding negation
uint256 constant pMINUS_2_1 = 0xFFFFFFFF00000001000000000000000000000000FFFFFFFFFFFFFFFFFFFFFFFD;
// -2 mod(n), used to speed up inversion operations
uint256 constant nMINUS_2_1 = 0xFFFFFFFF00000000FFFFFFFFFFFFFFFFBCE6FAADA7179E84F3B9CAC2FC63254F;

//precomputed 2^128.G
//0x447d739beedb5e67fb982fd588c6766efc35ff7dc297eac357c84fc9d789bd85
uint256 constant gpow2p128_x_1 = 30978927491535595270285342502287618780579786685182435011955893029189825707397;
uint256 constant gpow2p128_y_1= 20481551163499472379222416201371726725754635744576161296521936142531318405938;
